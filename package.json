{
  "name": "express-memorize",
  "version": "1.3.0",
  "description": "In-memory cache middleware for Express.js. Caches GET responses with optional TTL — zero dependencies, fully typed.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/ElJijuna/express-memorize#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/express-memorize.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/express-memorize/issues"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "fakeTimers": {
      "enableGlobally": false
    }
  },
  "keywords": [
    "express",
    "middleware",
    "cache",
    "memory",
    "ttl",
    "in-memory",
    "http-cache",
    "expressjs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typedoc": "^0.28.18",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^5.0.0"
  }
}
