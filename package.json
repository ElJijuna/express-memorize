{
  "name": "express-memorize",
  "version": "1.0.0",
  "description": "In-memory cache middleware for Express.js. Caches GET responses with optional TTL — zero dependencies, fully typed.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/ElJijuna/express-memorize#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/express-memorize.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/express-memorize/issues"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "fakeTimers": {
      "enableGlobally": false
    }
  },
  "keywords": ["express", "middleware", "cache", "memory", "ttl", "in-memory", "http-cache", "expressjs"],
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
