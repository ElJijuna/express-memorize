{
  "name": "express-memorize",
  "version": "2.5.1",
  "description": "In-memory cache middleware for Express.js. Caches GET responses with optional TTL — zero dependencies, fully typed.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "default": "./dist/adapters/express.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "default": "./dist/adapters/hono.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "default": "./dist/adapters/fastify.js"
    },
    "./koa": {
      "types": "./dist/adapters/koa.d.ts",
      "default": "./dist/adapters/koa.js"
    },
    "./nestjs": {
      "types": "./dist/adapters/nestjs.d.ts",
      "default": "./dist/adapters/nestjs.js"
    },
    "./fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "default": "./dist/adapters/fetch.js"
    }
  },
  "homepage": "https://github.com/ElJijuna/express-memorize#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/express-memorize.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/express-memorize/issues"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "npm run lint && npm run format:check && npm test && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build",
    "bench": "tsx bench/index.ts",
    "bench:eventloop": "tsx bench/eventloop-only.ts",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "express",
    "middleware",
    "cache",
    "memory",
    "ttl",
    "in-memory",
    "http-cache",
    "expressjs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@koa/router": ">=10.0.0",
    "@nestjs/common": ">=9.0.0",
    "@nestjs/core": ">=9.0.0",
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "hono": ">=4.0.0",
    "koa": ">=2.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@koa/router": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    },
    "koa": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@koa/router": "^15.6.0",
    "@semantic-release/changelog": "^6.0.3",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/koa": "^3.0.2",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "fastify": "^5.6.2",
    "hono": "^4.12.16",
    "jest": "^30.4.2",
    "koa": "^3.2.0",
    "semantic-release": "^25.0.3",
    "super-configs": "^1.15.0",
    "tinybench": "^6.0.2",
    "tsx": "^4.22.1",
    "typedoc": "^0.28.18",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^6.0.3"
  },
  "author": "pilmee <pilmee@gmail.com> (https://github.com/ElJijuna)",
  "publishConfig": {
    "access": "public"
  }
}
