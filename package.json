{
  "name": "express-memorize",
  "version": "1.4.0",
  "description": "In-memory cache middleware for Express.js. Caches GET responses with optional TTL — zero dependencies, fully typed.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/adapters/hono.d.ts",
      "default": "./dist/adapters/hono.js"
    },
    "./fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "default": "./dist/adapters/fetch.js"
    }
  },
  "homepage": "https://github.com/ElJijuna/express-memorize#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/express-memorize.git"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/express-memorize/issues"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm test && npm run build",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "keywords": [
    "express",
    "middleware",
    "cache",
    "memory",
    "ttl",
    "in-memory",
    "http-cache",
    "expressjs"
  ],
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0",
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "hono": "^4.12.16",
    "jest": "^29.0.0",
    "semantic-release": "^24.2.9",
    "ts-jest": "^29.0.0",
    "typedoc": "^0.28.18",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^5.0.0"
  }
}
